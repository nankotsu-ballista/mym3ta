<h1>テンプレートを作成</h1>
<h1>キャラクター</h1>
<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <%= form_with(model: @champ, url: set_tempting_true_champs_path, method: :post) do |f| %>
      <%= f.label :name %>
      <%= f.text_field :name %>

      <%= f.label :image %>
      <%= f.file_field :image %>

      <%= f.submit "新しいキャラクターを追加", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<div>
  <% @champl.each do |champ| %>
    <div style="display: inline-block; width: 140px; margin: 12px; text-align: center; vertical-align: top;">
      <% if champ.image.attached? %>
        <%= image_tag champ.image.variant(resize_to_fill: [100, 100]).processed %>
      <% end %>

      <div style="margin-top: 8px;">
        <span><%= champ.name %></span>
        <span style="margin-left: 8px;"><%= champ.champid %></span>
      </div>

      <div style="margin-top: 8px;">
        <%= button_to "Delete", champ_path(champ),
            method: :delete,
            data: { confirm: "Are you sure?" },
            class: "btn btn-danger btn-sm" %>
      </div>
    </div>
  <% end %>
</div>

<h1>状況</h1>
<%= form_with(model: @joukyou, url: joukyous_path) do |f| %>
  <%= f.label :name %>
  <%= f.text_field :name %>

  <%= f.label :image %>
  <%= f.file_field :image %>

  <%= f.submit "新しい状況を追加", class: "btn btn-primary" %>
<% end %>


<div>
  <% @joukyoul.each do |joukyou| %>
    <div style="display: inline-block; width: 140px; margin: 12px; text-align: center; vertical-align: top;">
      <% if joukyou.image.attached? %>
        <%= image_tag joukyou.image.variant(resize_to_fill: [100, 100]).processed %>
      <% end %>

      <div style="margin-top: 8px;">
        <span><%= joukyou.name %></span>
      </div>

      <div style="margin-top: 8px;">
        <%= button_to "Delete", joukyou_path(joukyou),
            method: :delete,
            data: { confirm: "Are you sure?" },
            class: "btn btn-danger btn-sm" %>
      </div>
    </div>
  <% end %>
</div>













<%= link_to "完成！", hontouroku_path, class: "btn btn-warning", style: "font-size: 1.2em; padding: 10px 20px;" %>
<%= button_to "テンプレートを完全に削除", reset_temp_path, method: :post, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>